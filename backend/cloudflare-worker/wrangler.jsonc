{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ziwei-llm-proxy",
  "main": "src/index.js",
  "compatibility_date": "2026-06-09",
  "vars": {
    "ALLOWED_ORIGIN": "https://wqianv.github.io,https://tanxj.xyz,https://www.tanxj.xyz",
    "LLM_BASE_URL": "https://api.deepseek.com",
    "LLM_MODEL": "deepseek-v4-pro",
    "PUBLIC_HOURLY_LIMIT": "3",
    "PUBLIC_DAILY_LIMIT": "8",
    "PUBLIC_IP_DAILY_LIMIT": "60"
  },
  "kv_namespaces": [
    {
      "binding": "LLM_JOBS",
      "id": "ac192f4dc78b415097fb2e0c9fea778c"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "LLM_JOB_QUEUE",
        "queue": "ziwei-llm-jobs"
      }
    ],
    "consumers": [
      {
        "queue": "ziwei-llm-jobs"
      }
    ]
  },
  "routes": [
    {
      "pattern": "api.tanxj.xyz",
      "custom_domain": true
    }
  ]
}
