# Copy this file to .env.local and fill in your DeepSeek key.
# .env.local is already ignored by git.
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional for static deployments such as GitHub Pages.
# Point this to your own serverless proxy. Do not expose DEEPSEEK_API_KEY
# in browser-side VITE_* variables.
VITE_DEEPSEEK_PROXY_URL=
