# Copy this file to .env.local and fill in your OpenAI-compatible API key.
# .env.local is already ignored by git.
LLM_API_KEY=replace-with-your-provider-key
LLM_MODEL=deepseek-v4-pro
LLM_BASE_URL=https://api.deepseek.com

# Optional: protect the local/dev proxy with an access key.
PROXY_ACCESS_KEY=replace-with-your-proxy-access-key

# Legacy DeepSeek names are still supported.
DEEPSEEK_API_KEY=replace-with-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional for static deployments such as GitHub Pages.
# Point this to your own serverless proxy. Do not expose LLM_API_KEY or
# PROXY_ACCESS_KEY in browser-side VITE_* variables.
VITE_LLM_PROXY_URL=
VITE_DEEPSEEK_PROXY_URL=
