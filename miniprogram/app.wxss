page {
  min-height: 100vh;
  background: #f5f1e8;
  color: #241d19;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
    "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

button {
  margin: 0;
  border-radius: 8rpx;
  font: inherit;
}

button::after {
  border: 0;
}
