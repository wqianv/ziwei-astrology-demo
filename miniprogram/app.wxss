page {
  min-height: 100vh;
  background: #f3f6f2;
  color: #1f2a25;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
    "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

button {
  margin: 0;
  border-radius: 10rpx;
  font: inherit;
  box-sizing: border-box;
}

button::after {
  border: 0;
}
