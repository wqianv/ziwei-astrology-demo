page {
  min-height: 100vh;
  background: #f4f6f2;
  color: #1f2a25;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
    "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

button {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 10rpx;
  font: inherit;
  line-height: 1.2;
  box-sizing: border-box;
}

button::after {
  border: 0;
}

button[disabled] {
  opacity: 0.58;
}
