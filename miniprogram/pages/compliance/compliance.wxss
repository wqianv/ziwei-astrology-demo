.page {
  min-height: 100vh;
  padding: 46rpx 32rpx 64rpx;
  box-sizing: border-box;
}

.heading {
  margin-bottom: 24rpx;
}

.eyebrow {
  margin-bottom: 12rpx;
  color: #9a6334;
  font-size: 24rpx;
  line-height: 1.3;
}

.title {
  color: #241d19;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
}

.section {
  margin-top: 18rpx;
  border: 1rpx solid rgba(36, 29, 25, 0.1);
  border-radius: 12rpx;
  padding: 26rpx 24rpx;
  background: rgba(255, 250, 240, 0.9);
}

.section-title {
  color: #241d19;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.paragraph {
  margin-top: 12rpx;
  color: #5c4e44;
  font-size: 27rpx;
  line-height: 1.75;
}
