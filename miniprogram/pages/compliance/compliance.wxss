.page {
  min-height: 100vh;
  padding: 30rpx 28rpx 76rpx;
  box-sizing: border-box;
}

.heading {
  margin-bottom: 20rpx;
}

.eyebrow {
  margin-bottom: 10rpx;
  color: #5d7c72;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
}

.title {
  color: #1f2a25;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.section {
  margin-top: 18rpx;
  border: 1rpx solid rgba(31, 42, 37, 0.09);
  border-radius: 12rpx;
  padding: 24rpx 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(34, 55, 48, 0.06);
}

.section-title {
  color: #1f2a25;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.paragraph {
  margin-top: 12rpx;
  color: #4f5f58;
  font-size: 27rpx;
  line-height: 1.7;
}
