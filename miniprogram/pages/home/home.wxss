.page {
  min-height: 100vh;
  padding: 30rpx 28rpx 76rpx;
  box-sizing: border-box;
}

.hero {
  padding: 8rpx 2rpx 24rpx;
}

.eyebrow {
  margin-bottom: 14rpx;
  color: #5d7c72;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
}

.title {
  color: #1f2a25;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.12;
}

.summary {
  margin-top: 18rpx;
  color: #4f5f58;
  font-size: 27rpx;
  line-height: 1.6;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin: 10rpx 0 22rpx;
}

.secondary-actions {
  display: flex;
  gap: 14rpx;
}

.primary,
.secondary {
  width: 100%;
  height: 86rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.secondary-actions .secondary {
  flex: 1;
  min-width: 0;
  padding: 0 12rpx;
  font-size: 28rpx;
}

.primary {
  background: #2a6f5f;
  color: #ffffff;
}

.secondary {
  border: 1rpx solid rgba(42, 111, 95, 0.24);
  background: #ffffff;
  color: #2a6f5f;
}

.panel {
  overflow: hidden;
  border: 1rpx solid rgba(31, 42, 37, 0.09);
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(34, 55, 48, 0.06);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 112rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid rgba(31, 42, 37, 0.08);
  box-sizing: border-box;
}

.row > view:first-child {
  flex: 1;
  min-width: 0;
}

.row:last-child {
  border-bottom: 0;
}

.row-title {
  color: #1f2a25;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.row-text {
  margin-top: 8rpx;
  color: #5d6d66;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
}

.chevron {
  flex: 0 0 auto;
  width: 32rpx;
  color: #9f7b2f;
  font-size: 40rpx;
  line-height: 1;
  text-align: right;
}

.notice {
  margin-top: 22rpx;
  border: 1rpx solid rgba(42, 111, 95, 0.1);
  border-radius: 12rpx;
  padding: 20rpx 22rpx;
  background: rgba(255, 255, 255, 0.68);
  color: #66766f;
  font-size: 24rpx;
  line-height: 1.65;
}
