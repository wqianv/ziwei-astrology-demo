.page {
  min-height: 100vh;
  padding: 38rpx 28rpx 64rpx;
  box-sizing: border-box;
}

.hero {
  padding: 18rpx 0 28rpx;
}

.eyebrow {
  margin-bottom: 14rpx;
  color: #5d7c72;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
}

.title {
  color: #1f2a25;
  font-size: 50rpx;
  font-weight: 800;
  line-height: 1.12;
}

.summary {
  margin-top: 18rpx;
  color: #4f5f58;
  font-size: 27rpx;
  line-height: 1.6;
}

.actions {
  margin: 16rpx 0 24rpx;
}

.actions button + button {
  margin-top: 18rpx;
}

.primary,
.secondary {
  height: 84rpx;
  line-height: 84rpx;
  font-size: 30rpx;
}

.primary {
  background: #2a6f5f;
  color: #ffffff;
}

.secondary {
  border: 1rpx solid rgba(42, 111, 95, 0.24);
  background: #ffffff;
  color: #2a6f5f;
}

.panel {
  overflow: hidden;
  border: 1rpx solid rgba(31, 42, 37, 0.09);
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(34, 55, 48, 0.06);
}

.row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(31, 42, 37, 0.08);
}

.row:last-child {
  border-bottom: 0;
}

.row-title {
  color: #1f2a25;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.row-text {
  margin-top: 8rpx;
  color: #5d6d66;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
}

.chevron {
  flex: 0 0 auto;
  color: #9f7b2f;
  font-size: 42rpx;
}

.notice {
  margin-top: 28rpx;
  color: #66766f;
  font-size: 24rpx;
  line-height: 1.65;
}
