.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 64rpx;
  box-sizing: border-box;
}

.hero {
  padding: 36rpx 0 28rpx;
}

.eyebrow {
  margin-bottom: 14rpx;
  color: #9a6334;
  font-size: 24rpx;
  line-height: 1.3;
}

.title {
  color: #241d19;
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1.12;
}

.summary {
  margin-top: 18rpx;
  color: #5c4e44;
  font-size: 28rpx;
  line-height: 1.7;
}

.actions {
  margin: 18rpx 0 30rpx;
}

.actions button + button {
  margin-top: 18rpx;
}

.primary,
.secondary {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
}

.primary {
  background: #2f7668;
  color: #fffaf0;
}

.secondary {
  border: 1rpx solid rgba(47, 118, 104, 0.26);
  background: #fffaf0;
  color: #2f7668;
}

.panel {
  overflow: hidden;
  border: 1rpx solid rgba(36, 29, 25, 0.1);
  border-radius: 12rpx;
  background: rgba(255, 250, 240, 0.9);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(36, 29, 25, 0.08);
}

.row:last-child {
  border-bottom: 0;
}

.row-title {
  color: #241d19;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.row-text {
  margin-top: 8rpx;
  color: #6c5544;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
}

.chevron {
  flex: 0 0 auto;
  color: #9a6334;
  font-size: 42rpx;
}

.notice {
  margin-top: 28rpx;
  color: #766659;
  font-size: 24rpx;
  line-height: 1.65;
}
