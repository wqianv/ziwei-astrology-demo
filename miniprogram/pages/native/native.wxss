.page {
  min-height: 100vh;
  padding: 30rpx 28rpx 78rpx;
  box-sizing: border-box;
}

.hero {
  padding: 8rpx 2rpx 22rpx;
}

.eyebrow {
  margin-bottom: 10rpx;
  color: #5d7c72;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
}

.title {
  color: #1f2a25;
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1.15;
}

.summary {
  margin-top: 14rpx;
  color: #4f5f58;
  font-size: 26rpx;
  line-height: 1.62;
}

.panel,
.summary-card,
.section-card {
  border: 1rpx solid rgba(31, 42, 37, 0.09);
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(34, 55, 48, 0.06);
}

.panel {
  margin-top: 18rpx;
  padding: 24rpx 22rpx;
}

.panel-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.panel-heading > view {
  min-width: 0;
}

.panel-title {
  color: #1f2a25;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.panel-note,
.privacy,
.hint {
  margin-top: 10rpx;
  color: #5d6d66;
  font-size: 24rpx;
  line-height: 1.58;
}

.form-panel {
  padding-bottom: 18rpx;
}

.field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 96rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(31, 42, 37, 0.08);
  box-sizing: border-box;
}

.form-panel picker:last-of-type .field,
.field:last-child {
  border-bottom: 0;
}

.label {
  flex: 0 0 112rpx;
  color: #60736c;
  font-size: 24rpx;
  line-height: 1.4;
}

.value {
  flex: 1;
  min-width: 0;
  min-height: 72rpx;
  border: 1rpx solid rgba(31, 42, 37, 0.12);
  border-radius: 12rpx;
  padding: 0 18rpx;
  background: #f8faf7;
  color: #1f2a25;
  font-size: 28rpx;
  line-height: 72rpx;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.segmented {
  display: flex;
  flex: 1;
  min-width: 0;
  gap: 10rpx;
}

.seg-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 12rpx;
  border: 1rpx solid rgba(42, 111, 95, 0.24);
  border-radius: 12rpx;
  background: #f8faf7;
  color: #2a6f5f;
  font-size: 28rpx;
  line-height: 1;
}

.seg-button.active {
  border-color: #d6ad50;
  background: #d6ad50;
  color: #1f2a25;
  font-weight: 800;
}

.summary-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 16rpx;
}

.summary-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  width: calc(50% - 7rpx);
  min-height: 126rpx;
  margin-top: 0;
  padding: 18rpx 16rpx;
  box-sizing: border-box;
}

.summary-card:first-child {
  width: 100%;
  min-height: 112rpx;
}

.summary-title {
  color: #60736c;
  font-size: 23rpx;
  line-height: 1.45;
}

.summary-value {
  min-width: 0;
  margin-top: 10rpx;
  color: #1f2a25;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.46;
  word-break: break-word;
}

.ziwei-panel {
  padding: 24rpx 16rpx 22rpx;
}

.ziwei-panel > .panel-heading,
.ziwei-panel > .subsection-title {
  padding: 0 6rpx;
}

.palace-focus {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 0 6rpx;
}

.focus-card {
  flex: 1;
  min-width: 0;
  border-radius: 12rpx;
  padding: 18rpx 14rpx;
  background: #f8faf7;
  box-sizing: border-box;
}

.focus-label {
  color: #60736c;
  font-size: 23rpx;
  line-height: 1.4;
}

.focus-value {
  margin-top: 8rpx;
  color: #9f7b2f;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.focus-text {
  margin-top: 8rpx;
  color: #31423b;
  font-size: 24rpx;
  line-height: 1.45;
}

.chart-board {
  position: relative;
  display: flex;
  flex-wrap: wrap;
  overflow: hidden;
  width: 100%;
  height: 664rpx;
  margin-top: 18rpx;
  border: 1rpx solid rgba(31, 42, 37, 0.1);
  border-radius: 12rpx;
  background: #f7faf6;
  box-sizing: border-box;
}

.board-cell {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  width: 25%;
  height: 166rpx;
  border-right: 1rpx solid rgba(31, 42, 37, 0.08);
  border-bottom: 1rpx solid rgba(31, 42, 37, 0.08);
  padding: 12rpx 9rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.board-cell:nth-child(4n) {
  border-right: 0;
}

.board-cell:nth-child(n + 13) {
  border-bottom: 0;
}

.board-cell.is-empty {
  background: #f7faf6;
}

.board-cell.is-selected {
  background: rgba(214, 173, 80, 0.16);
  box-shadow: inset 0 0 0 3rpx #d6ad50;
}

.board-cell.is-ming .board-name {
  color: #9f7b2f;
}

.board-cell.is-body .board-branch {
  color: #2a6f5f;
}

.board-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6rpx;
}

.board-name {
  min-width: 0;
  color: #1f2a25;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.board-branch {
  flex: 0 0 auto;
  color: #8b6b2a;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.2;
}

.board-stars {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 8rpx;
  color: #31423b;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-word;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.board-tags {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: auto;
  padding-top: 8rpx;
}

.mini-tag {
  flex: 0 0 auto;
  min-width: 27rpx;
  height: 27rpx;
  border-radius: 999rpx;
  background: #d6ad50;
  color: #1f2a25;
  font-size: 17rpx;
  font-weight: 800;
  line-height: 27rpx;
  text-align: center;
}

.mini-tag.muted {
  background: #e5eee9;
  color: #2a6f5f;
}

.board-decade {
  min-width: 0;
  color: #71837c;
  font-size: 17rpx;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.board-center {
  position: absolute;
  top: 166rpx;
  left: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 50%;
  height: 332rpx;
  border: 1rpx solid rgba(42, 111, 95, 0.16);
  padding: 18rpx;
  background: #f0f6f2;
  box-sizing: border-box;
  text-align: center;
  pointer-events: none;
}

.center-title {
  color: #1f2a25;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.center-line {
  margin-top: 8rpx;
  color: #5d6d66;
  font-size: 22rpx;
  line-height: 1.35;
  word-break: break-word;
}

.selected-palace {
  margin-top: 16rpx;
  border: 1rpx solid rgba(42, 111, 95, 0.12);
  border-radius: 12rpx;
  padding: 20rpx 18rpx;
  background: #fbfcfa;
}

.selected-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.selected-heading > view {
  min-width: 0;
}

.selected-title {
  color: #1f2a25;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.3;
}

.selected-subtitle {
  margin-top: 6rpx;
  color: #60736c;
  font-size: 24rpx;
  line-height: 1.45;
}

.selected-tags {
  display: flex;
  flex: 0 0 auto;
  gap: 6rpx;
}

.selected-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.selected-item {
  width: calc(50% - 6rpx);
  margin-top: 0;
  border-radius: 10rpx;
  padding: 14rpx 12rpx;
  background: #f4f8f5;
  box-sizing: border-box;
}

.selected-label {
  color: #71837c;
  font-size: 22rpx;
  line-height: 1.35;
}

.selected-value {
  margin-top: 8rpx;
  color: #26362f;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.45;
  word-break: break-word;
}

.subsection-title {
  margin-top: 24rpx;
  color: #1f2a25;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
}

.palace-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 10rpx;
}

.palace-card {
  width: 100%;
  min-height: 0;
  margin-top: 0;
  border: 1rpx solid rgba(42, 111, 95, 0.12);
  border-radius: 12rpx;
  padding: 18rpx 16rpx;
  background: #fbfcfa;
  box-sizing: border-box;
}

.palace-card.is-ming {
  border-color: rgba(214, 173, 80, 0.72);
  background: rgba(214, 173, 80, 0.12);
}

.palace-card.is-body {
  border-color: rgba(42, 111, 95, 0.34);
}

.palace-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.palace-name {
  color: #1f2a25;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
}

.palace-branch {
  flex: 0 0 auto;
  color: #9f7b2f;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.25;
}

.palace-text {
  margin-top: 12rpx;
  color: #31423b;
  font-size: 24rpx;
  line-height: 1.45;
}

.palace-stars {
  margin-top: 12rpx;
  border-radius: 10rpx;
  padding: 10rpx 12rpx;
  background: #f4f8f5;
}

.star-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 6rpx 0;
}

.star-label {
  flex: 0 0 56rpx;
  color: #71837c;
  font-size: 22rpx;
  line-height: 1.45;
}

.star-value {
  flex: 1;
  min-width: 0;
  color: #26362f;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
  word-break: break-word;
}

.palace-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: #d6ad50;
  color: #1f2a25;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.tag.muted {
  background: #e5eee9;
  color: #2a6f5f;
}

.star-status {
  color: #71837c;
  font-size: 21rpx;
  line-height: 1.45;
}

.primary,
.secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  margin-top: 22rpx;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1;
  box-sizing: border-box;
}

.primary {
  background: #2a6f5f;
  color: #ffffff;
}

.secondary {
  border: 1rpx solid rgba(42, 111, 95, 0.24);
  background: #ffffff;
  color: #2a6f5f;
}

.notice {
  display: block;
  margin-top: 14rpx;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.notice.success {
  background: rgba(42, 111, 95, 0.1);
  color: #2a6f5f;
}

.notice.warning {
  background: rgba(214, 173, 80, 0.18);
  color: #6d5520;
}

.notice.error {
  background: rgba(159, 47, 39, 0.09);
  color: #9f2f27;
}

.consent-group {
  margin-top: 16rpx;
}

.consent-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  border: 1rpx solid rgba(42, 111, 95, 0.14);
  border-radius: 12rpx;
  padding: 16rpx;
  background: #f8faf7;
  box-sizing: border-box;
}

.consent-checkbox {
  flex: 0 0 auto;
  margin-top: 2rpx;
  transform: scale(0.84);
  transform-origin: top left;
}

.consent-text {
  flex: 1;
  min-width: 0;
  color: #4f5f58;
  font-size: 24rpx;
  line-height: 1.55;
}

.text-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 144rpx;
  height: 56rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(42, 111, 95, 0.18);
  background: #f8faf7;
  color: #2a6f5f;
  font-size: 23rpx;
  line-height: 1;
  box-sizing: border-box;
}

.compact-action {
  height: 72rpx;
  margin-top: 14rpx;
  font-size: 27rpx;
}

.report-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.report-actions .compact-action {
  flex: 1;
  min-width: 0;
  margin-top: 0;
  padding: 0 10rpx;
  font-size: 25rpx;
}

.progress-track {
  height: 12rpx;
  overflow: hidden;
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: #dde8e3;
}

.progress-bar {
  width: 76%;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #2a6f5f, #d6ad50, #2a6f5f);
  animation: progressPulse 1.4s ease-in-out infinite alternate;
}

.report-header {
  align-items: flex-start;
}

.badge {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  background: #edf3f0;
  color: #5d6d66;
  font-size: 23rpx;
  line-height: 1.3;
  white-space: nowrap;
}

.section-list {
  margin-top: 18rpx;
}

.section-card {
  margin-top: 12rpx;
  padding: 22rpx 20rpx;
}

.section-title {
  color: #1f2a25;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.35;
}

.section-content,
.section-empty {
  margin-top: 14rpx;
  color: #31423b;
  font-size: 27rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.section-empty {
  color: #71837c;
}

.web-entry {
  margin-top: 24rpx;
}

@keyframes progressPulse {
  from {
    transform: translateX(-18%);
  }

  to {
    transform: translateX(22%);
  }
}
