.page {
  min-height: 100vh;
  padding: 34rpx 28rpx 64rpx;
  box-sizing: border-box;
}

.hero {
  padding: 12rpx 0 22rpx;
}

.eyebrow {
  margin-bottom: 10rpx;
  color: #5d7c72;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
}

.title {
  color: #1f2a25;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.15;
}

.summary {
  margin-top: 14rpx;
  color: #4f5f58;
  font-size: 26rpx;
  line-height: 1.6;
}

.panel,
.summary-card,
.section-card {
  border: 1rpx solid rgba(31, 42, 37, 0.09);
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(34, 55, 48, 0.06);
}

.panel {
  margin-top: 16rpx;
  padding: 24rpx;
}

.panel-title {
  color: #1f2a25;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.field {
  margin-top: 18rpx;
}

.label {
  color: #60736c;
  font-size: 24rpx;
  line-height: 1.4;
}

.value {
  min-height: 74rpx;
  margin-top: 8rpx;
  border: 1rpx solid rgba(31, 42, 37, 0.12);
  border-radius: 10rpx;
  padding: 0 20rpx;
  background: #f8faf7;
  color: #1f2a25;
  font-size: 28rpx;
  line-height: 74rpx;
}

.segmented {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.seg-button {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border: 1rpx solid rgba(42, 111, 95, 0.24);
  background: #f8faf7;
  color: #2a6f5f;
  font-size: 28rpx;
}

.seg-button.active {
  border-color: #d6ad50;
  background: #d6ad50;
  color: #1f2a25;
  font-weight: 800;
}

.summary-grid {
  margin-top: 16rpx;
}

.summary-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  min-height: 0;
  margin-top: 12rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
}

.summary-card:first-child {
  display: block;
  margin-top: 0;
}

.summary-card:first-child .summary-title {
  display: block;
  flex: none;
}

.summary-card:first-child .summary-value {
  margin-top: 8rpx;
}

.summary-title {
  flex: 0 0 148rpx;
  color: #60736c;
  font-size: 24rpx;
  line-height: 1.5;
}

.summary-value {
  flex: 1;
  min-width: 0;
  margin-top: 0;
  color: #1f2a25;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-all;
}

.privacy,
.hint {
  margin-top: 12rpx;
  color: #5d6d66;
  font-size: 24rpx;
  line-height: 1.6;
}

.primary,
.secondary {
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  margin-top: 22rpx;
  font-size: 29rpx;
}

.primary {
  background: #2a6f5f;
  color: #ffffff;
}

.primary[disabled] {
  opacity: 0.62;
}

.secondary {
  border: 1rpx solid rgba(42, 111, 95, 0.24);
  background: #ffffff;
  color: #2a6f5f;
}

.notice {
  display: block;
  margin-top: 14rpx;
  border-radius: 10rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.notice.success {
  background: rgba(42, 111, 95, 0.1);
  color: #2a6f5f;
}

.notice.warning {
  background: rgba(214, 173, 80, 0.18);
  color: #6d5520;
}

.notice.error {
  background: rgba(159, 47, 39, 0.09);
  color: #9f2f27;
}

.text-button {
  flex: 0 0 auto;
  min-width: 148rpx;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(42, 111, 95, 0.18);
  background: #f8faf7;
  color: #2a6f5f;
  font-size: 23rpx;
}

.compact-action {
  height: 72rpx;
  line-height: 72rpx;
  margin-top: 14rpx;
  font-size: 27rpx;
}

.progress-track {
  height: 12rpx;
  overflow: hidden;
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: #dde8e3;
}

.progress-bar {
  width: 76%;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #2a6f5f, #d6ad50, #2a6f5f);
  animation: progressPulse 1.4s ease-in-out infinite alternate;
}

.report-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.badge {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  background: #edf3f0;
  color: #5d6d66;
  font-size: 23rpx;
}

.section-list {
  margin-top: 18rpx;
}

.section-card {
  margin-top: 12rpx;
  padding: 24rpx;
}

.section-title {
  color: #1f2a25;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.section-content,
.section-empty {
  margin-top: 14rpx;
  color: #31423b;
  font-size: 27rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.section-empty {
  color: #71837c;
}

.web-entry {
  margin-top: 24rpx;
}

@keyframes progressPulse {
  from {
    transform: translateX(-18%);
  }

  to {
    transform: translateX(22%);
  }
}
