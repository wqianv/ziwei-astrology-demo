.page {
  min-height: 100vh;
  padding: 42rpx 28rpx 64rpx;
  box-sizing: border-box;
}

.hero {
  padding: 20rpx 0 24rpx;
}

.eyebrow {
  margin-bottom: 12rpx;
  color: #9a6334;
  font-size: 24rpx;
  line-height: 1.3;
}

.title {
  color: #241d19;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.15;
}

.summary {
  margin-top: 14rpx;
  color: #5c4e44;
  font-size: 27rpx;
  line-height: 1.7;
}

.panel,
.summary-card,
.section-card {
  border: 1rpx solid rgba(36, 29, 25, 0.1);
  border-radius: 12rpx;
  background: rgba(255, 250, 240, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(36, 29, 25, 0.07);
}

.panel {
  margin-top: 18rpx;
  padding: 24rpx;
}

.panel-title {
  color: #241d19;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.35;
}

.field {
  margin-top: 20rpx;
}

.label {
  color: #7b6b5d;
  font-size: 24rpx;
  line-height: 1.4;
}

.value {
  min-height: 76rpx;
  margin-top: 8rpx;
  border: 1rpx solid rgba(36, 29, 25, 0.13);
  border-radius: 8rpx;
  padding: 0 20rpx;
  background: #fffaf0;
  color: #241d19;
  font-size: 29rpx;
  line-height: 76rpx;
}

.segmented {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.seg-button {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border: 1rpx solid rgba(47, 118, 104, 0.28);
  background: #fffaf0;
  color: #2f7668;
  font-size: 28rpx;
}

.seg-button.active {
  background: #e7c06b;
  color: #241d19;
}

.summary-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.summary-card {
  width: calc(50% - 7rpx);
  min-height: 142rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.summary-title {
  color: #8a6344;
  font-size: 23rpx;
}

.summary-value {
  margin-top: 10rpx;
  color: #241d19;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
}

.privacy,
.hint {
  margin-top: 12rpx;
  color: #6c5544;
  font-size: 24rpx;
  line-height: 1.65;
}

.primary,
.secondary {
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  margin-top: 22rpx;
  font-size: 29rpx;
}

.primary {
  background: #2f7668;
  color: #fffaf0;
}

.primary[disabled] {
  opacity: 0.62;
}

.secondary {
  border: 1rpx solid rgba(47, 118, 104, 0.28);
  background: #fffaf0;
  color: #2f7668;
}

.notice {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 14rpx;
  border-radius: 8rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.notice.success {
  background: rgba(47, 118, 104, 0.1);
  color: #2f7668;
}

.notice.warning {
  display: block;
  background: rgba(231, 192, 107, 0.2);
  color: #765121;
}

.notice.error {
  display: block;
  background: rgba(159, 47, 39, 0.09);
  color: #9f2f27;
}

.text-button {
  flex: 0 0 auto;
  max-width: 176rpx;
  height: 50rpx;
  line-height: 50rpx;
  padding: 0 18rpx;
  background: #fffaf0;
  color: #2f7668;
  font-size: 23rpx;
}

.compact-action {
  height: 72rpx;
  line-height: 72rpx;
  margin-top: 14rpx;
  font-size: 27rpx;
}

.progress-track {
  height: 12rpx;
  overflow: hidden;
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: #e0d2c0;
}

.progress-bar {
  width: 76%;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #2f7668, #e7c06b, #2f7668);
  animation: progressPulse 1.4s ease-in-out infinite alternate;
}

.report-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.badge {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  background: #f1e5d4;
  color: #6c5544;
  font-size: 23rpx;
}

.section-list {
  margin-top: 18rpx;
}

.section-card {
  margin-top: 14rpx;
  padding: 24rpx;
}

.section-title {
  color: #241d19;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.35;
}

.section-content,
.section-empty {
  margin-top: 14rpx;
  color: #3c3028;
  font-size: 27rpx;
  line-height: 1.75;
  white-space: pre-wrap;
}

.section-empty {
  color: #8a6344;
}

.web-entry {
  margin-top: 24rpx;
}

@keyframes progressPulse {
  from {
    transform: translateX(-18%);
  }

  to {
    transform: translateX(22%);
  }
}
