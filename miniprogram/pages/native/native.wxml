<view class="page">
  <view class="hero">
    <view class="eyebrow">native mini program</view>
    <view class="title">原生排盘</view>
    <view class="summary">出生信息、四柱摘要、紫微十二宫和 LLM 解读都在小程序内完成；网页版完整盘继续保留用于校验。</view>
  </view>

  <view class="panel form-panel">
    <view class="panel-heading">
      <view>
        <view class="panel-title">出生信息</view>
        <view class="panel-note">本机用 iztro 生成命盘摘要，生成解读时才请求后端。</view>
      </view>
    </view>

    <picker mode="date" value="{{birthDate}}" bindchange="handleBirthDateChange">
      <view class="field">
        <view class="label">生日</view>
        <view class="value">{{birthDate}}</view>
      </view>
    </picker>

    <picker range="{{birthTimes}}" value="{{birthTimeIndex}}" bindchange="handleBirthTimeChange">
      <view class="field">
        <view class="label">时辰</view>
        <view class="value">{{birthTimeText}}</view>
      </view>
    </picker>

    <view class="field">
      <view class="label">性别</view>
      <view class="segmented">
        <button
          wx:for="{{genderOptions}}"
          wx:key="value"
          data-index="{{index}}"
          class="seg-button {{item.active ? 'active' : ''}}"
          bindtap="selectGender"
        >
          {{item.label}}
        </button>
      </view>
    </view>
  </view>

  <view class="summary-grid">
    <view class="summary-card" wx:for="{{localCards}}" wx:key="title">
      <view class="summary-title">{{item.title}}</view>
      <view class="summary-value">{{item.value}}</view>
    </view>
  </view>

  <view class="panel ziwei-panel">
    <view class="panel-heading">
      <view>
        <view class="panel-title">紫微十二宫</view>
        <view class="panel-note">{{profile.ziwei.note}}</view>
      </view>
    </view>

    <view class="palace-focus">
      <view class="focus-card">
        <view class="focus-label">命宫</view>
        <view class="focus-value">{{profile.ziwei.mingPalace.branch}}</view>
        <view class="focus-text">{{profile.ziwei.mingPalace.starStatus}} · {{profile.ziwei.mingPalace.focus}}</view>
      </view>
      <view class="focus-card">
        <view class="focus-label">身宫</view>
        <view class="focus-value">{{profile.ziwei.bodyPalace.branch}}</view>
        <view class="focus-text">{{profile.ziwei.bodyPalace.name}} · {{profile.ziwei.bodyPalace.starStatus}}</view>
      </view>
    </view>

    <view class="chart-board">
      <view
        class="board-cell {{item.empty ? 'is-empty' : ''}} {{item.isSelected ? 'is-selected' : ''}} {{item.isMing ? 'is-ming' : ''}} {{item.isBody ? 'is-body' : ''}}"
        wx:for="{{ziweiBoardCells}}"
        wx:key="key"
        data-name="{{item.name}}"
        bindtap="selectPalace"
      >
        <block wx:if="{{!item.empty}}">
          <view class="board-topline">
            <text class="board-name">{{item.name}}</text>
            <text class="board-branch">{{item.branch}}</text>
          </view>
          <view class="board-stars">{{item.boardStarText || item.majorStarsText}}</view>
          <view class="board-tags">
            <text wx:if="{{item.isMing}}" class="mini-tag">命</text>
            <text wx:if="{{item.isBody}}" class="mini-tag muted">身</text>
            <text class="board-decade">{{item.decadalText}}</text>
          </view>
        </block>
      </view>

      <view class="board-center">
        <view class="center-title">命盘</view>
        <view class="center-line">{{profile.birth.lunar}}</view>
        <view class="center-line">{{profile.ziwei.fiveElementsClass}}</view>
        <view class="center-line">命主 {{profile.ziwei.soul}} · 身主 {{profile.ziwei.body}}</view>
      </view>
    </view>

    <view class="selected-palace">
      <view class="selected-heading">
        <view>
          <view class="selected-title">{{selectedPalace.name}} · {{selectedPalace.branch}}</view>
          <view class="selected-subtitle">{{selectedPalace.focus}}</view>
        </view>
        <view class="selected-tags">
          <text wx:if="{{selectedPalace.isMing}}" class="tag">命</text>
          <text wx:if="{{selectedPalace.isBody}}" class="tag muted">身</text>
        </view>
      </view>
      <view class="selected-grid">
        <view class="selected-item">
          <view class="selected-label">主星</view>
          <view class="selected-value">{{selectedPalace.majorStarsText}}</view>
        </view>
        <view class="selected-item">
          <view class="selected-label">辅星</view>
          <view class="selected-value">{{selectedPalace.minorStarsText}}</view>
        </view>
        <view class="selected-item">
          <view class="selected-label">杂曜</view>
          <view class="selected-value">{{selectedPalace.adjectiveStarsText}}</view>
        </view>
        <view class="selected-item">
          <view class="selected-label">大限</view>
          <view class="selected-value">{{selectedPalace.decadalText}}</view>
        </view>
      </view>
    </view>

    <view class="subsection-title">十二宫明细</view>

    <view class="palace-grid">
      <view
        class="palace-card {{item.isMing ? 'is-ming' : ''}} {{item.isBody ? 'is-body' : ''}}"
        wx:for="{{ziweiPalaces}}"
        wx:key="name"
      >
        <view class="palace-head">
          <view class="palace-name">{{item.name}}</view>
          <view class="palace-branch">{{item.branch}}</view>
        </view>
        <view class="palace-text">{{item.focus}}</view>
        <view class="palace-stars">
          <view class="star-row">
            <text class="star-label">主星</text>
            <text class="star-value">{{item.majorStarsText}}</text>
          </view>
          <view class="star-row">
            <text class="star-label">辅星</text>
            <text class="star-value">{{item.minorStarsText}}</text>
          </view>
          <view class="star-row">
            <text class="star-label">大限</text>
            <text class="star-value">{{item.decadalText}}</text>
          </view>
        </view>
        <view class="palace-meta">
          <text wx:if="{{item.isMing}}" class="tag">命</text>
          <text wx:if="{{item.isBody}}" class="tag muted">身</text>
          <text class="star-status">{{item.adjectiveStarsText}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-heading report-header">
      <view>
        <view class="panel-title">LLM 解读</view>
        <view class="panel-note">请求会发送到 Cloudflare Worker；后端访问密钥只保存在本机微信。</view>
      </view>
      <button class="text-button" bindtap="openSettings">
        {{proxyKeySaved ? '更换密钥' : '设置密钥'}}
      </button>
    </view>

    <view wx:if="{{proxyKeySaved}}" class="notice success">{{saveNotice || '已读取本机保存的后端访问密钥。'}}</view>
    <view wx:else class="notice warning">还没有保存后端访问密钥。先去设置页保存，再回来生成解读。</view>

    <checkbox-group class="consent-group" bindchange="handleConsentChange">
      <label class="consent-row">
        <checkbox
          class="consent-checkbox"
          value="accepted"
          checked="{{llmConsentAccepted}}"
          color="#2a6f5f"
        />
        <view class="consent-text">
          我确认生成解读时，将当前出生信息、命盘摘要和必要请求内容发送到后端代理与模型服务；解读结果仅作传统文化与娱乐参考。
        </view>
      </label>
    </checkbox-group>

    <button
      class="primary"
      loading="{{loading}}"
      disabled="{{loading || !canGenerate}}"
      bindtap="generateReport"
    >
      {{generateButtonText}}
    </button>

    <button wx:if="{{!proxyKeySaved}}" class="secondary compact-action" bindtap="openSettings">去设置访问密钥</button>
    <view wx:if="{{error}}" class="notice error">{{error}}</view>
  </view>

  <view wx:if="{{loading}}" class="panel progress-panel">
    <view class="panel-title">正在生成</view>
    <view class="progress-track">
      <view class="progress-bar"></view>
    </view>
    <view class="privacy">{{loadingTip}}</view>
  </view>

  <view wx:if="{{hasReport}}" class="panel report-panel">
    <view class="panel-heading report-header">
      <view>
        <view class="panel-title">LLM 解读已生成</view>
        <view class="panel-note">{{reportMeta}}</view>
      </view>
      <view class="badge">{{matchedCount}} / 9</view>
    </view>
    <view class="privacy">{{usageText}}</view>
  </view>

  <view class="section-list">
    <view class="section-card" wx:for="{{sections}}" wx:key="id">
      <view class="section-title">{{item.title}}</view>
      <view wx:if="{{item.hasContent}}" class="section-content">{{item.content}}</view>
      <view wx:else class="section-empty">生成后会填入这一节。原生版已接入紫微与四柱摘要，完整盘面仍可查看网页版。</view>
    </view>
  </view>

  <button class="secondary web-entry" bindtap="openWebApp">查看网页版完整盘</button>
</view>
