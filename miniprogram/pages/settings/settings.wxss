.page {
  min-height: 100vh;
  padding: 42rpx 28rpx 64rpx;
  box-sizing: border-box;
}

.hero {
  padding: 20rpx 0 24rpx;
}

.eyebrow {
  margin-bottom: 12rpx;
  color: #9a6334;
  font-size: 24rpx;
  line-height: 1.3;
}

.title {
  color: #241d19;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.15;
}

.summary {
  margin-top: 14rpx;
  color: #5c4e44;
  font-size: 27rpx;
  line-height: 1.7;
}

.panel {
  margin-top: 18rpx;
  border: 1rpx solid rgba(36, 29, 25, 0.1);
  border-radius: 12rpx;
  padding: 24rpx;
  background: rgba(255, 250, 240, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(36, 29, 25, 0.07);
}

.panel-title {
  color: #241d19;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.35;
}

.field {
  margin-top: 20rpx;
}

.label {
  color: #7b6b5d;
  font-size: 24rpx;
  line-height: 1.4;
}

.key-input {
  min-height: 76rpx;
  margin-top: 8rpx;
  border: 1rpx solid rgba(36, 29, 25, 0.13);
  border-radius: 8rpx;
  padding: 0 20rpx;
  background: #fffaf0;
  color: #241d19;
  font-size: 29rpx;
  line-height: 76rpx;
}

.hint {
  margin-top: 12rpx;
  color: #6c5544;
  font-size: 24rpx;
  line-height: 1.65;
}

.primary,
.secondary {
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  margin-top: 20rpx;
  font-size: 29rpx;
}

.primary {
  background: #2f7668;
  color: #fffaf0;
}

.primary[disabled] {
  opacity: 0.62;
}

.secondary {
  border: 1rpx solid rgba(47, 118, 104, 0.28);
  background: #fffaf0;
  color: #2f7668;
}

.notice {
  margin-top: 14rpx;
  border-radius: 8rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.notice.success {
  background: rgba(47, 118, 104, 0.1);
  color: #2f7668;
}

.notice.warning {
  background: rgba(231, 192, 107, 0.2);
  color: #765121;
}

.domain-row,
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(36, 29, 25, 0.08);
}

.domain-row:last-child,
.row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.domain-main {
  min-width: 0;
}

.domain-title,
.row-title {
  color: #241d19;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.domain-value,
.row-text {
  margin-top: 8rpx;
  color: #6c5544;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
}

.copy-button {
  flex: 0 0 auto;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(47, 118, 104, 0.28);
  background: #fffaf0;
  color: #2f7668;
  font-size: 24rpx;
}

.chevron {
  flex: 0 0 auto;
  color: #9a6334;
  font-size: 42rpx;
}
