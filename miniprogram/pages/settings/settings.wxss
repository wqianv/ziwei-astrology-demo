.page {
  min-height: 100vh;
  padding: 30rpx 28rpx 76rpx;
  box-sizing: border-box;
}

.hero {
  padding: 8rpx 2rpx 22rpx;
}

.eyebrow {
  margin-bottom: 10rpx;
  color: #5d7c72;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
}

.title {
  color: #1f2a25;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.15;
}

.summary {
  margin-top: 14rpx;
  color: #4f5f58;
  font-size: 26rpx;
  line-height: 1.6;
}

.panel {
  margin-top: 18rpx;
  border: 1rpx solid rgba(31, 42, 37, 0.09);
  border-radius: 12rpx;
  padding: 24rpx 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(34, 55, 48, 0.06);
}

.panel-title {
  color: #1f2a25;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.field {
  margin-top: 18rpx;
}

.label {
  color: #60736c;
  font-size: 24rpx;
  line-height: 1.4;
}

.key-input {
  min-height: 74rpx;
  margin-top: 8rpx;
  border: 1rpx solid rgba(31, 42, 37, 0.12);
  border-radius: 12rpx;
  padding: 0 20rpx;
  background: #f8faf7;
  color: #1f2a25;
  font-size: 28rpx;
  line-height: 74rpx;
  box-sizing: border-box;
}

.hint {
  margin-top: 12rpx;
  color: #5d6d66;
  font-size: 24rpx;
  line-height: 1.6;
}

.primary,
.secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  margin-top: 20rpx;
  font-size: 29rpx;
  font-weight: 700;
}

.primary {
  background: #2a6f5f;
  color: #ffffff;
}

.secondary {
  border: 1rpx solid rgba(42, 111, 95, 0.24);
  background: #ffffff;
  color: #2a6f5f;
}

.danger-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  margin-top: 20rpx;
  border: 1rpx solid rgba(159, 47, 39, 0.24);
  background: #fffafa;
  color: #9f2f27;
  font-size: 29rpx;
  font-weight: 700;
}

.compact-action {
  height: 72rpx;
  margin-top: 14rpx;
  font-size: 27rpx;
}

.notice {
  margin-top: 14rpx;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.notice.success {
  background: rgba(42, 111, 95, 0.1);
  color: #2a6f5f;
}

.notice.warning {
  background: rgba(214, 173, 80, 0.18);
  color: #6d5520;
}

.notice.error {
  background: rgba(159, 47, 39, 0.09);
  color: #9f2f27;
}

.domain-row,
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 110rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(31, 42, 37, 0.08);
  box-sizing: border-box;
}

.domain-row:last-child,
.row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.domain-main {
  flex: 1;
  min-width: 0;
}

.row > view:first-child {
  flex: 1;
  min-width: 0;
}

.domain-title,
.row-title {
  color: #1f2a25;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.domain-value,
.row-text {
  margin-top: 8rpx;
  color: #5d6d66;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
}

.copy-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 104rpx;
  height: 60rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(42, 111, 95, 0.24);
  background: #f8faf7;
  color: #2a6f5f;
  font-size: 24rpx;
}

.chevron {
  flex: 0 0 auto;
  width: 32rpx;
  color: #9f7b2f;
  font-size: 42rpx;
  line-height: 1;
  text-align: right;
}
